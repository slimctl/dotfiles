[core]
  editor = nvim
  autocrlf = input

[push]
  autoSetupRemote = true

[pull]
  rebase = true

[color]
  ui = auto

[init]
  defaultBranch = main

[includeIf "hasconfig:remote.*.url:*github.com*/**"]
  path = ~/.config/git/config_github

[includeIf "gitdir:~/projects/poa/"]
  path = ~/.config/git/config_poa

